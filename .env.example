# ==============================================================================
# Configurações do Servidor
# ==============================================================================
FLASK_DEBUG=True

# ==============================================================================
# Credenciais da API Google Gemini
# Obtenha sua chave gratuita em: https://aistudio.google.com/
# ==============================================================================
GEMINI_API_KEY=SUA_CHAVE_DE_API_AQUI

# ==============================================================================
# Chave de Autenticação para Projetos Externos
# Deixe em branco se quiser permitir requisições sem autenticação (ideal para testes).
# Se configurado, outros projetos devem enviar o cabeçalho: X-API-KEY: <sua_chave>
# ==============================================================================
API_AUTH_KEY=

# ==============================================================================
# Banco de Dados (PostgreSQL)
# Deixe comentado/em branco para usar o SQLite local padrão (apipi.db).
# Para usar o PostgreSQL, remova o '#' e preencha seus dados de conexão:
# ==============================================================================
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/nome_do_banco

# ==============================================================================
# Segurança de Domínios (CORS)
# Deixe '*' para permitir requisições de qualquer site (ótimo para testes).
# Em produção, coloque seus domínios separados por vírgula (ex: https://meusite.com)
# ==============================================================================
ALLOWED_ORIGINS=*


